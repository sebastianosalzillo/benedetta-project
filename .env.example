# Environment Configuration

# Copy this file to .env and fill in values as needed.
# Most values have working defaults — you only need to set what you want to override.
# NEVER commit .env to git.

# =============================================================
# AI Brain
# =============================================================

# Default Ollama model (used when brain=ollama)
# NYX_OLLAMA_MODEL=qwen3.5:0.8b

# Ollama API base URL
# OLLAMA_HOST=http://127.0.0.1:11434

# =============================================================
# Kokoro TTS (optional local text-to-speech)
# =============================================================

# Host and port for the Kokoro FastAPI server
# KOKORO_HOST=127.0.0.1
# KOKORO_PORT=5037

# Default speaker voice
# KOKORO_DEFAULT_SPEAKER=if_sara

# Path to Python executable for launching Kokoro server
# KOKORO_PYTHON=C:\Users\yourname\miniconda3\python.exe

# TTS provider: "kokoro" or "none"
# AVATAR_TTS_PROVIDER=kokoro

# =============================================================
# PinchTab Browser Agent (optional)
# =============================================================

# PinchTab server host and port
# PINCHTAB_HOST=127.0.0.1
# PINCHTAB_PORT=9867

# Auth token for PinchTab (leave empty if not configured)
# PINCHTAB_TOKEN=

# Run PinchTab in headless mode
# PINCHTAB_HEADLESS=false

# =============================================================
# pywinauto-MCP Desktop Automation (optional, Windows only)
# =============================================================

# PYWINAUTO_MCP_HOST=127.0.0.1
# PYWINAUTO_MCP_PORT=10789

# =============================================================
# Agent / ACP Timeouts
# =============================================================

# Overall agent response timeout in milliseconds
# AVATAR_ACP_TIMEOUT_MS=120000

# Computer action (click/type) timeout in milliseconds
# AVATAR_COMPUTER_ACTION_TIMEOUT_MS=20000

# Max browser autopilot steps
# AVATAR_BROWSER_AGENT_HARD_LIMIT=64

# =============================================================
# Workspace & Memory
# =============================================================

# Max characters per workspace file read into context
# NYX_WORKSPACE_FILE_MAX_CHARS=4000

# Max total workspace characters across all files
# NYX_WORKSPACE_TOTAL_MAX_CHARS=24000

# =============================================================
# Features
# =============================================================

# Enable real-time canvas panel
# NYX_ENABLE_LIVE_CANVAS=true
