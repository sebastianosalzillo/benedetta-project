{
  "name": "benedetta-project",
  "version": "1.1.0",
  "main": "electron/main.js",
  "scripts": {
    "dev:vite": "vite --port 5174",
    "dev:electron": "cross-env VITE_DEV_SERVER_URL=http://localhost:5174 electron .",
    "dev": "concurrently -k \"npm run dev:vite\" \"npm run dev:electron\"",
    "build": "vite build",
    "start": "electron .",
    "test:smoke": "npm run test:unit -- --runInBand",
    "test:unit": "jest",
    "test:e2e": "node e2e/electron-smoke.js",
    "test:e2e:avatar": "node e2e/avatar-regression.js",
    "test:e2e:ci": "npm run build && npm run test:e2e",
    "test": "npm run test:unit -- --runInBand",
    "bench:kokoro": "node scripts/measure_kokoro_latency.js",
    "dist": "electron-builder"
  },
  "dependencies": {
    "ajv": "^6.14.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "d3": "^6.7.0",
    "framer-motion": "^12.34.3",
    "lru-cache": "^10.4.3",
    "ollama": "^0.6.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "dompurify": "^3.1.7",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "es-module-shims": "^1.7.1",
    "jest": "^30.3.0",
    "marked": "^14.1.3",
    "microsoft-cognitiveservices-speech-sdk": "^1.49.0",
    "playwright": "^1.59.1",
    "three": "^0.180.0",
    "vite": "^7.3.1"
  },
  "build": {
    "appId": "com.benedetta.project",
    "productName": "Benedetta",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
