{
  "name": "avatar-acp-desktop",
  "version": "0.1.0",
  "main": "electron/main.js",
  "scripts": {
    "dev:vite": "vite --port 5174",
    "dev:electron": "cross-env VITE_DEV_SERVER_URL=http://localhost:5174 electron .",
    "dev": "concurrently -k \"npm run dev:vite\" \"npm run dev:electron\"",
    "build": "vite build",
    "start": "electron ."
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "framer-motion": "^12.34.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^40.6.1",
    "vite": "^7.3.1"
  }
}
